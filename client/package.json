{
  "name": "realm-client",
  "version": "3.10.0",
  "main": "main.js",
  "scripts": {
    "start":       "electron .",
    "build:win":   "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron":         "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId":       "com.realm.app",
    "productName": "Realm",
    "files": [
      "main.js",
      "preload.js",
      "node_modules/**/*"
    ],
    "extraResources": [],
    "publish": {
      "provider": "github",
      "owner":    "nefesec",
      "repo":     "realm"
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon":   "assets/icon.ico"
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "icon":   "assets/icon.png"
    },
    "nsis": {
      "oneClick":        true,
      "perMachine":      false,
      "allowToChangeInstallationDirectory": false,
      "language":        "1036"
    }
  }
}
